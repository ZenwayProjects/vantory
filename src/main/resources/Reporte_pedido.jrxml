	<property name="com.jaspersoft.studio.data.sql.tables" value="" />
	<property name="com.jaspersoft.studio.data.defaultdataadapter">
		<![CDATA[U:Postgres & DB:agropro]]>
	</property>
	<parameter name="ped_id" class="java.lang.Integer" />
	<queryString>
		<![CDATA[SELECT p.ped_id AS header_pedido_id,
    p.ped_fecha_hora AS header_fecha_hora,
    pp.prp_nombre AS item_producto,
    pi.pei_cantidad AS item_cantidad,
    u.uni_nombre AS item_unidad,
    a.alm_nombre AS header_almacen_nombre,
    s.sed_nombre AS header_sede,
    e.emp_nombre AS header_empresa
FROM pedido AS p
    JOIN pedido_item AS pi ON p.ped_id = pi.pei_pedido_id
    JOIN producto_presentacion AS pp ON pi.pei_producto_presentacion_id = pp.prp_id
    JOIN producto AS pr ON pp.prp_producto_id = pr.pro_id
    JOIN unidad AS u ON pp.prp_unidad_id = u.uni_id
    JOIN almacen AS a ON p.ped_almacen_id = a.alm_id
    JOIN sede AS s ON a.alm_sede_id = s.sed_id
    JOIN empresa AS e ON s.sed_empresa_id = e.emp_id
WHERE p.ped_id = $P{ped_id}]]>
	</queryString>
