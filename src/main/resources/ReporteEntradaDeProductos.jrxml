	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="Agropro Data Adapter"/>
	<parameter name="EmpresaUsuario" class="java.lang.Long">
		<parameterDescription><![CDATA[Empresa del usuario]]></parameterDescription>
	</parameter>
	<queryString language="SQL">
		<![CDATA[select k.kar_id as id_pedido, p.prp_descripcion as producto, ki.kai_cantidad as unidades, a.alm_nombre as almacen, k.kar_fecha_hora as fecha_pedido, e.emp_nombre as cliente
from kardex as k, kardex_item as ki , tipo_movimiento as tm, producto_presentacion as p, almacen as a, empresa as e, sede s
where k.kar_id = ki.kai_kardex_id
and ki.kai_producto_presentacion_id = p.prp_id
and k.kar_tipo_movimiento_id = tm.tim_id
and k.kar_almacen_id = a.alm_id
and k.kar_cliente_proveedor = e.emp_id
and a.alm_sede_id = s.sed_id
and s.sed_empresa_id = $P{EmpresaUsuario}
and tm.tim_movimiento = 1
order by fecha_pedido desc]]>
	</queryString>
