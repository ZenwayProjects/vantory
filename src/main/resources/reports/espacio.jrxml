	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<parameter name="condicion" class="java.lang.String"/>
	<parameter name="logo_empresa" class="java.lang.String"/>
	<query language="sql"><![CDATA[SELECT 
    esp.esp_id,
    esp.esp_bloque_id,
    esp.esp_tipo_espacio_id,
    esp.esp_nombre,
    esp.esp_descripcion,
    esp.esp_empresa_id,
    esp.esp_estado_id,
    esp.esp_direccion,

    emp.emp_id,
    emp.emp_nombre,
    emp.emp_estado_id,
    emp.emp_celular,
    emp.emp_correo,
    emp.emp_contacto,
    emp.emp_logo,

    esa.esa_id,
    esa.esa_produccion_id,
    esa.esa_tipo_actividad_id,
    esa.esa_fecha_hora,
    esa.esa_cantidad,
    esa.esa_unidad_id,
    esa.esa_precio,
    esa.esa_evaluacion_id,
    esa.esa_descripcion,
    esa.esa_estado_id,
    esa.esa_empresa_id,

    eso.eso_id,
    eso.eso_espacio_id,
    eso.eso_actividad_ocupacion_id,
    eso.eso_fecha_inicio,
    eso.eso_fecha_fin,
    eso.eso_estado_id,
    eso.eso_empresa_id,

    est.est_id,
    est.est_nombre,

    tie.tie_id,
    tie.tie_nombre,
    tie.tie_descripcion,
    tie.tie_estado_id,
    tie.tie_empresa_id,

    blo.blo_id,
    blo.blo_nombre,
    blo.blo_direccion,
    
    alm.alm_id,
    alm.alm_nombre,
    
    sed.sed_id,
    sed.sed_nombre

FROM espacio esp
JOIN empresa emp ON esp.esp_empresa_id = emp.emp_id
LEFT JOIN espacio_actividad esa ON esp.esp_id = esa.esa_estado_id
LEFT JOIN espacio_ocupacion eso ON esp.esp_id = eso.eso_espacio_id
LEFT JOIN almacen alm ON alm.alm_espacio_id = esp.esp_id
JOIN estado est ON esp.esp_estado_id = est.est_id
JOIN tipo_espacio tie ON esp.esp_tipo_espacio_id = tie.tie_id
JOIN bloque blo ON esp.esp_bloque_id = blo.blo_id
JOIN sede sed ON blo.blo_sede_id = sed.sed_id

WHERE 

	$P!{condicion} 


]]></query>
