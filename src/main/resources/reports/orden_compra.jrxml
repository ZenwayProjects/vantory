<jasperReport name="Reporte_orden_compra" language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="25e1c055-c456-49cb-ba58-2e49dfeaf867">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="agrotest-0.3.1"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w1" value="357"/>
	<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w2" value="632"/>
	<parameter name="logo_empresa" class="java.lang.String"/>
	<parameter name="condicion" class="java.lang.String"/>
	<query language="sql"><![CDATA[SELECT 
    oc.orc_id AS header_orden_compra,
    oc.orc_pedido_id AS header_pedido,
    oc.orc_fecha_hora AS header_fecha_hora,
    pp.prp_nombre AS item_producto, 
    oci.oci_cantidad AS item_cantidad, 
    u.uni_nombre AS item_unidad, 
    oci.oci_precio AS item_precio,
    s.sed_nombre AS header_sede, 
    blo.blo_nombre AS header_bloque,
    esp.esp_nombre AS header_espacio,
    a.alm_nombre AS header_almacen, 
    e.emp_nombre AS header_empresa,
    e.emp_contacto AS header_contacto,
    e.emp_correo AS header_correo,
    e.emp_celular AS header_telefono,
    e.emp_logo AS header_empresa_logo,
    pro.pro_nombre AS header_proveedor,
    CONCAT(per.per_nombre, ' ', per.per_apellido) AS header_responsable,
    est.est_nombre AS header_estado_orden_compra 

FROM 
    orden_compra AS oc
    JOIN orden_compra_item AS oci ON oc.orc_id = oci.oci_orden_compra_id
    JOIN producto_presentacion AS pp ON oci.oci_producto_presentacion_id = pp.prp_id
    JOIN producto AS pr ON pp.prp_producto_id = pr.pro_id
    JOIN unidad AS u ON pp.prp_unidad_id = u.uni_id
    JOIN pedido AS pe ON pe.ped_id = oc.orc_pedido_id
    JOIN almacen AS a ON pe.ped_almacen_id = a.alm_id
    JOIN espacio AS esp ON a.alm_espacio_id = esp.esp_id
    JOIN bloque AS blo ON esp.esp_bloque_id = blo.blo_id
    JOIN sede AS s ON blo.blo_sede_id = s.sed_id
    JOIN empresa AS e ON s.sed_empresa_id = e.emp_id
    JOIN proveedor AS pro ON oc.orc_proveedor_id = pro.pro_id
    JOIN persona AS per ON e.emp_persona_id = per.per_id
    JOIN estado AS est ON oc.orc_estado_id = est.est_id

WHERE 
   		$P!{condicion} 

]]></query>
