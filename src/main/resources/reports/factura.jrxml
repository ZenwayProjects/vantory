<!-- Created with Jaspersoft Studio version 7.0.3.final using JasperReports Library version 7.0.3-41034ca841d452f3305ba55b9042260aaa1ab5dd  -->
<jasperReport name="Reporte_factura" language="java" pageWidth="700" pageHeight="900" columnWidth="660" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="25e1c055-c456-49cb-ba58-2e49dfeaf867">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="agrotest-0.3.1"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<parameter name="logo_empresa" class="java.lang.String"/>
	<parameter name="condicion" class="java.lang.String"/>
	<query language="sql"><![CDATA[SELECT  
    k.kar_id AS header_id,
    e.emp_id AS header_empresa_id,
    e.emp_nombre AS header_empresa,
    e.emp_identificacion AS header_empresa_identificacion,
    e.emp_persona_id AS header_persona_id,
    s.sed_id AS header_sede_id,
    s.sed_nombre AS header_sede,
    s.sed_direccion AS header_sede_direccion,

    k.kar_almacen_id AS header_almacen_id,
    al.alm_nombre AS header_almacen,
    al.alm_direccion AS header_almacen_direccion,

    m.mun_id AS header_municipio_id,
    m.mun_nombre AS header_municipio,

    e.emp_correo AS header_correo,
    e.emp_contacto AS header_contacto,
    e.emp_celular AS header_telefono,
    e.emp_logo AS header_empresa_logo,

    CONCAT(per.per_nombre, ' ', per.per_apellido) AS header_responsable,

    cp.emp_id AS header_cliente_proveedor_id,
    cp.emp_nombre AS header_cliente_proveedor,

    esp.esp_id AS header_espacio_id,
    esp.esp_nombre AS header_espacio,

    blo.blo_id AS header_bloque_id,
    blo.blo_nombre AS header_bloque,

    p.pro_producto_categoria_id AS item_categoria_producto_id,
    p.pro_nombre AS item_producto_presentacion,
    pp.prp_id AS item_producto_id,
    pp.prp_nombre AS item_presentacion_nombre,
    u.uni_nombre AS item_unidad,
    m2.mar_nombre AS item_marca,

    k.kar_fecha_hora AS item_fecha,
    k.kar_tipo_movimiento_id AS item_tipo_movimiento,
    ki.kai_cantidad AS item_cantidad,
    ki.kai_precio AS item_precio,
    ki.kai_fecha_vencimiento AS item_fecha_vencimiento,

    CASE 
        WHEN tm.tim_movimiento_id = 1 THEN ki.kai_cantidad
        ELSE 0 
    END AS item_entrada,

    CASE 
        WHEN tm.tim_movimiento_id = 2 THEN ki.kai_cantidad
        ELSE 0 
    END AS item_salida,

    (
        SELECT SUM(sub_ki.kai_cantidad * pp2.prp_cantidad)
        FROM kardex_item sub_ki
        JOIN kardex sub_k ON sub_ki.kai_kardex_id = sub_k.kar_id
        JOIN producto_presentacion pp2 ON sub_ki.kai_producto_presentacion_id = pp2.prp_id
        WHERE 
            pp2.prp_producto_id = pp.prp_producto_id
            AND sub_ki.kai_id <= ki.kai_id
    ) AS item_saldo

FROM kardex_item ki
JOIN kardex k ON ki.kai_kardex_id = k.kar_id
JOIN tipo_movimiento tm ON k.kar_tipo_movimiento_id = tm.tim_id
JOIN producto_presentacion pp ON ki.kai_producto_presentacion_id = pp.prp_id
JOIN producto p ON pp.prp_producto_id = p.pro_id
JOIN unidad u ON pp.prp_unidad_id = u.uni_id
JOIN marca m2 ON pp.prp_marca_id = m2.mar_id
JOIN almacen al ON k.kar_almacen_id = al.alm_id
JOIN espacio esp ON al.alm_espacio_id = esp.esp_id
JOIN bloque blo ON esp.esp_bloque_id = blo.blo_id
JOIN sede s ON blo.blo_sede_id = s.sed_id
JOIN municipio m ON s.sed_municipio_id = m.mun_id
JOIN empresa e ON k.kar_empresa_id = e.emp_id
JOIN persona per ON e.emp_persona_id = per.per_id
JOIN empresa cp ON k.kar_cliente_proveedor_id = cp.emp_id

WHERE 
   		$P!{condicion} 
]]></query>
