	</variable>
	<variable name="subtotal" class="java.lang.Double">
		<expression><![CDATA[$F{item_cantidad}.doubleValue() * $F{item_entrada}.doubleValue()]]></expression>
	</variable>
	<variable name="iva" class="java.lang.Double">
		<expression><![CDATA[$V{subtotal} * 0.19]]></expression>
	</variable>
	<variable name="total" class="java.lang.Double">
		<expression><![CDATA[$V{subtotal} + $V{iva}]]></expression>
	</variable>
