	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="ovw-db"/>
	<parameter name="logo_empresa" class="java.lang.String"/>
	<parameter name="condicion" class="java.lang.String"/>
	<query language="SQL"><![CDATA[SELECT 
    pro.pro_id,
    pro.pro_empresa_id,
    pro.pro_fecha_creacion,
    pro.pro_estado_id,
    pro.pro_tipo_identificacion_id,
    pro.pro_nombre,
    pro.pro_celular,
    pro.pro_contacto,
    pro.pro_correo,
    pro.pro_identificacion,
    
    emp.emp_id,
    emp.emp_tipo_identificacion_id,
    emp.emp_nombre,
    emp.emp_estado_id,
    emp.emp_celular,
    emp.emp_correo,
    emp.emp_contacto,
    emp.emp_logo,
    
    est.est_nombre

FROM proveedor AS pro
JOIN empresa AS emp ON pro.pro_empresa_id = emp.emp_id
JOIN estado AS est ON pro.pro_estado_id = est.est_id

WHERE

	$P!{condicion} 

]]></query>
