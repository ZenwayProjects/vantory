<jasperReport name="Reporte_proovedores" language="java" pageWidth="700" pageHeight="842" columnWidth="660" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="ca6f58fe-144d-496c-9c4d-9752ea5b95ef">
