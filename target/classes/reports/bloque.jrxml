<jasperReport name="Reporte_bloque" language="java" pageWidth="700" pageHeight="842" columnWidth="660" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="0a3157f7-8ee4-43df-ba9f-2995d7efa4b4">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="agrotest-0.2.1"/>
	<parameter name="logo_empresa" class="java.lang.String"/>
	<parameter name="condicion" class="java.lang.String"/>
	<query language="SQL"><![CDATA[SELECT 
    b.blo_id,
    b.blo_sede_id,
    b.blo_tipo_bloque_id,
    b.blo_nombre,
    b.blo_numero_pisos,
    b.blo_estado_id,
    b.blo_empresa_id,
    b.blo_direccion,
    
    tb.tib_id,
    tb.tib_nombre,
    
    s.sed_id,
    s.sed_nombre,
    s.sed_direccion,
    
    ts.tis_id,
    ts.tis_nombre,
    
    e.emp_id,
    e.emp_nombre,
    e.emp_celular,
    e.emp_correo,
    e.emp_contacto,
    e.emp_logo,

    est_bloque.est_id AS blo_estado_id,
    est_bloque.est_nombre AS blo_estado_nombre,

    est_sede.est_id AS sed_estado_id,
    est_sede.est_nombre AS sed_estado_nombre,
    
    alm.alm_id,
    alm.alm_nombre

FROM bloque b
JOIN tipo_bloque tb ON b.blo_tipo_bloque_id = tb.tib_id
JOIN sede s ON b.blo_sede_id = s.sed_id
JOIN tipo_sede ts ON s.sed_tipo_sede_id = ts.tis_id
JOIN empresa e ON b.blo_empresa_id = e.emp_id
JOIN estado est_bloque ON b.blo_estado_id = est_bloque.est_id
JOIN estado est_sede ON s.sed_estado_id = est_sede.est_id

-- Nuevas relaciones para llegar a almacen
LEFT JOIN espacio esp ON esp.esp_bloque_id = b.blo_id
LEFT JOIN almacen alm ON alm.alm_espacio_id = esp.esp_id

WHERE

	$P!{condicion} 

]]></query>
