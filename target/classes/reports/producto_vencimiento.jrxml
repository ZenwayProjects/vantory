<jasperReport name="producto_vencimiento" language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="6842db66-f825-4df7-9130-ffe18d149a3a">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="agrotest-0.3.1"/>
	<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w1" value="151"/>
	<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w2" value="844"/>
	<parameter name="logo_empresa" class="java.lang.String"/>
	<parameter name="condicion" class="java.lang.String"/>
	<query language="SQL"><![CDATA[SELECT 
    em.emp_nombre AS nombre_empresa,
    em.emp_logo AS logo_empresa,                

    p.pro_nombre AS nombre_producto,

    m.mun_nombre AS nombre_municipio,
    s.sed_nombre AS nombre_sede,
    b.blo_nombre AS nombre_bloque,
    e.esp_nombre AS nombre_espacio,
    a.alm_nombre AS nombre_almacen,

    k.kai_fecha_vencimiento AS fecha_vencimiento,
    k.kai_cantidad AS cantidad

FROM producto p
JOIN producto_presentacion pp ON p.pro_id = pp.prp_producto_id
JOIN kardex_item k ON pp.prp_id = k.kai_producto_presentacion_id
JOIN empresa em ON p.pro_empresa_id = em.emp_id
JOIN municipio m ON m.mun_empresa_id = em.emp_id
JOIN sede s ON s.sed_municipio_id = m.mun_id AND s.sed_empresa_id = em.emp_id
JOIN bloque b ON b.blo_sede_id = s.sed_id AND b.blo_empresa_id = em.emp_id
JOIN espacio e ON e.esp_bloque_id = b.blo_id AND e.esp_empresa_id = em.emp_id
JOIN almacen a ON a.alm_espacio_id = e.esp_id AND a.alm_empresa_id = em.emp_id

WHERE 
   		$P!{condicion} 

]]></query>
