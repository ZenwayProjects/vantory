<jasperReport name="Reporte_sede" language="java" pageWidth="700" pageHeight="842" columnWidth="660" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="9672b791-483d-40e1-bdfb-9f0cffcc81af">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="agrotest-0.2.1"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<parameter name="condicion" class="java.lang.String"/>
	<parameter name="logo_empresa" class="java.lang.String"/>
	<query language="sql"><![CDATA[SELECT 
    s.sed_id,
    s.sed_grupo_id,
    s.sed_tipo_sede_id,
    s.sed_empresa_id,
    s.sed_nombre,
    s.sed_municipio_id,
    s.sed_geolocalizacion,
    s.sed_coordenadas,
    s.sed_area,
    s.sed_comuna,
    s.sed_descripcion,
    s.sed_estado_id,
    s.sed_direccion,
    
    emp.emp_id,
    emp.emp_logo,
    emp.emp_nombre,
    emp.emp_contacto,
    emp.emp_celular,
    emp.emp_correo,
    
    g.gru_id,
    g.gru_nombre,
    
    m.mun_id,
    m.mun_nombre,
    
    d.dep_id,
    d.dep_nombre,
    
    p.pai_id,
    p.pai_nombre,
    
    ts.tis_id,
    ts.tis_nombre,
    
    est.est_nombre,

    alm.alm_id,
    alm.alm_nombre

FROM sede s
JOIN empresa emp ON s.sed_empresa_id = emp.emp_id
JOIN grupo g ON s.sed_grupo_id = g.gru_id
JOIN municipio m ON s.sed_municipio_id = m.mun_id
JOIN departamento d ON m.mun_departamento_id = d.dep_id
JOIN pais p ON d.dep_pais_id = p.pai_id
JOIN tipo_sede ts ON s.sed_tipo_sede_id = ts.tis_id
JOIN estado est ON s.sed_estado_id = est.est_id

LEFT JOIN bloque blo ON blo.blo_sede_id = s.sed_id
LEFT JOIN espacio esp ON esp.esp_bloque_id = blo.blo_id
LEFT JOIN almacen alm ON alm.alm_espacio_id = esp.esp_id

WHERE 
	$P!{condicion} 

]]></query>
