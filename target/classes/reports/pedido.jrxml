<!-- Created with Jaspersoft Studio version 7.0.3.final using JasperReports Library version 7.0.3-41034ca841d452f3305ba55b9042260aaa1ab5dd  -->
<jasperReport name="Reporte_pedido" language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="25e1c055-c456-49cb-ba58-2e49dfeaf867">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="agrotest-0.3.1"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w1" value="233"/>
	<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w2" value="761"/>
	<parameter name="logo_empresa" class="java.lang.String"/>
	<parameter name="condicion" class="java.lang.String"/>
	<query language="sql"><![CDATA[SELECT 
    p.ped_id AS header_pedido_id, 
    p.ped_fecha_hora AS header_fecha_hora, 
    pp.prp_nombre AS item_producto, 
    pi.pei_cantidad AS item_cantidad, 
    es.esp_nombre AS header_espacio,
    b.blo_nombre AS header_bloque,
    u.uni_nombre AS item_unidad, 
    mun.mun_nombre AS header_municipio,
    a.alm_nombre AS header_almacen_nombre, 
    s.sed_nombre AS header_sede, 
    e.emp_nombre AS header_empresa,
    e.emp_correo AS header_correo,
    e.emp_contacto AS header_contacto,
    CONCAT(per.per_nombre, ' ', per.per_apellido) AS header_responsable,
    est.est_nombre AS header_estado_pedido  

FROM 
    pedido AS p
    JOIN pedido_item AS pi ON p.ped_id = pi.pei_pedido_id
    JOIN producto_presentacion AS pp ON pi.pei_producto_presentacion_id = pp.prp_id
    JOIN producto AS pr ON pp.prp_producto_id = pr.pro_id
    JOIN unidad AS u ON pp.prp_unidad_id = u.uni_id
    JOIN almacen AS a ON p.ped_almacen_id = a.alm_id
    JOIN espacio AS es ON a.alm_espacio_id = es.esp_id
    JOIN bloque AS b ON es.esp_bloque_id = b.blo_id
    JOIN sede AS s ON b.blo_sede_id = s.sed_id
    JOIN municipio AS mun ON s.sed_municipio_id = mun.mun_id
    JOIN empresa AS e ON s.sed_empresa_id = e.emp_id
    JOIN persona AS per ON e.emp_persona_id = per.per_id
    JOIN estado AS est ON p.ped_estado_id = est.est_id

WHERE 
   		$P!{condicion} 
]]></query>
